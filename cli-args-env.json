{
  "name": "hono-pds",
  "description": "AT Protocol PDS server",
  "options": {
    "port": {
      "type": "number",
      "description": "Port to listen on",
      "env": "PORT",
      "default": 2583
    },
    "hostname": {
      "type": "string",
      "description": "Hostname to bind to",
      "env": "HOSTNAME",
      "default": "127.0.0.1"
    },
    "private-key-hex": {
      "type": "string",
      "description": "PDS private key as hex string",
      "env": "PDS_PRIVATE_KEY_HEX"
    },
    "did-web-services": {
      "type": "string",
      "description": "DID web services JSON",
      "env": "PDS_DID_WEB_SERVICES"
    },
    "public-hostname": {
      "type": "string",
      "description": "Public hostname for requestCrawl (may differ from bind hostname)",
      "env": "PDS_PUBLIC_HOSTNAME"
    },
    "crawlers": {
      "type": "string",
      "description": "Comma-separated relay URLs to notify on writes",
      "env": "PDS_CRAWLERS"
    }
  }
}
