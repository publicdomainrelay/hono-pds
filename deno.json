{
  "workspace": [
    "lib/common",
    "lib/abc/atproto-repo",
    "lib/atproto-repo-deno",
    "lib/hono-factory-atproto-repo-deno"
  ],
  "nodeModulesDir": "auto",
  "imports": {
    "@hono/hono": "jsr:@hono/hono@^4",
    "@atproto/crypto": "npm:@atproto/crypto@^0.5.0",
    "@atproto/identity": "npm:@atproto/identity@^0.5.0",
    "@std/assert": "jsr:@std/assert@^1",
    "@publicdomainrelay/hono-error-middleware": "../typescript-helpers/lib/hono-error-middleware/mod.ts",
    "@publicdomainrelay/logger": "../typescript-helpers/lib/logger/mod.ts",
    "@publicdomainrelay/sandbox-abc": "../deno-worker-sandbox/lib/abc/sandbox/mod.ts",
    "@publicdomainrelay/sandbox-deno": "../deno-worker-sandbox/lib/sandbox-deno/mod.ts"
  },
  "tasks": {
    "check": "deno check lib/common/mod.ts lib/abc/atproto-repo/mod.ts lib/atproto-repo-deno/mod.ts lib/hono-factory-atproto-repo-deno/mod.ts",
    "test": "deno test --allow-net --allow-env --unstable-kv test/",
    "test:sandbox": "deno test --allow-net --allow-env --allow-read --allow-write --unstable-kv --unstable-worker-options test/conformance/sandbox-conformance.test.ts",
    "test:conformance": "deno test --allow-net --allow-env --unstable-kv test/conformance/",
    "fmt": "deno fmt"
  },
  "fmt": {
    "lineWidth": 100
  }
}
