{
  "lexicon": 1,
  "id": "com.atproto.repo.createRecord",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Create a new record in the repository.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["collection", "record"],
          "properties": {
            "collection": {"type": "string", "description": "The NSID of the collection."},
            "rkey": {"type": "string", "description": "The record key, if not set will be randomly assigned."},
            "record": {"type": "unknown", "description": "The record itself."},
            "validate": {"type": "boolean", "description": "Whether to validate the record against the lexicon schema."}
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["uri", "cid"],
          "properties": {
            "uri": {"type": "string", "description": "The AT URI of the created record."},
            "cid": {"type": "string", "description": "The CID of the created record."}
          }
        }
      }
    }
  }
}
